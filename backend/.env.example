ENV=local
PORT=8080

DATABASE_URL=postgres://postgres:postgres@localhost:5432/kerf
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30
PASSWORD_PEPPER=your-pepper-string

CORS_ORIGIN=http://localhost:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=
GEMINI_API_KEY=
DEFAULT_MODEL=claude-sonnet-4-20250514

CLOUD_ENABLED=false
LOCAL_MODE=true

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./.kerf-storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL_BASE=
CDN_BASE_URL=

STEP_MAX_BYTES=200000000
UPLOAD_CHUNK_SIZE=5242880
UPLOAD_SESSION_TTL_HOURS=24

STEP_TESSELLATE_WORKERS=2
STEP_TESSELLATE_TIMEOUT_SEC=300
FEM_WORKERS=2
FEM_TIMEOUT_SEC=600
SIM_WORKERS=2
SIM_TIMEOUT_SEC=600

PYWORKER_URL=http://localhost:8090

SYSTEM_USER_EMAIL=
SYSTEM_USER_NAME=
