# .env.main.example — Kerf MAIN/production environment template (kerf.sh)
# Copy to .env.main and fill in real values before deploying.
# NEVER commit .env.main — it is gitignored.
# Lines marked XXX must be filled; deploy-fly.sh blocks on them.

# ── Mode ─────────────────────────────────────────────────────────────────────
CLOUD_ENABLED=true
KERF_LOCAL_MODE=false
# Flip KERF_CLOUD_BETA to false + supply CLOUD_PAYSTACK_* to start charging.
KERF_CLOUD_BETA=true

# ── Core secrets ─────────────────────────────────────────────────────────────
DATABASE_URL='postgresql://XXX_DB_USER:XXX_DB_PASS@XXX_DB_HOST/XXX_DB_NAME?sslmode=require'
JWT_SECRET=XXX_JWT_SECRET

# ── Object storage (Tigris / S3) ─────────────────────────────────────────────
KERF_STORAGE_S3_BUCKET=XXX_S3_BUCKET
KERF_STORAGE_S3_ACCESS_KEY=XXX_S3_ACCESS_KEY
KERF_STORAGE_S3_SECRET_KEY=XXX_S3_SECRET_KEY
KERF_STORAGE_S3_ENDPOINT=https://fly.storage.tigris.dev
KERF_STORAGE_S3_REGION=auto

# ── Domain / CORS ────────────────────────────────────────────────────────────
CORS_ORIGIN=https://kerf.sh
VITE_API_URL=https://kerf.sh

# ── Google OAuth ─────────────────────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=XXX_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=XXX_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URL=https://kerf.sh/auth/google/callback

# ── GitHub OAuth (cloud Git sync) ────────────────────────────────────────────
CLOUD_GITHUB_CLIENT_ID=XXX_GITHUB_CLIENT_ID
CLOUD_GITHUB_CLIENT_SECRET=XXX_GITHUB_CLIENT_SECRET
CLOUD_GITHUB_REDIRECT_URL=https://kerf.sh/auth/github/callback

# ── LLM providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=XXX_ANTHROPIC_API_KEY
MOONSHOT_API_KEY=
GEMINI_API_KEY=

# ── Transactional email ───────────────────────────────────────────────────────
# Choose a provider: smtp | resend | ses  (default: smtp)
# EMAIL_PROVIDER=smtp
# Default From address used by all outbound email.
# EMAIL_FROM=Kerf <noreply@kerf.app>
#
# Resend (https://resend.com) — set EMAIL_PROVIDER=resend and supply the key.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
#
# AWS SES v2 — set EMAIL_PROVIDER=ses and supply region + optional static keys.
# When running on an EC2/ECS instance with an IAM role, omit the key vars.
# SES_REGION=us-east-1
# SES_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# SES_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
#
# SMTP (legacy) — set EMAIL_PROVIDER=smtp and supply host/port/credentials.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
