# Kerf main (production) environment template.
#
# Copy to `.env.main` (gitignored) and replace XXX placeholders with real
# values, then run:
#   ./scripts/deploy-fly.sh        # main is the default
#
# This deploys to the `kerf` fly app + `kerf-workers`.
# Use Paystack LIVE keys here. Use a dedicated Neon project (not a branch
# of dev). DOUBLE-CHECK every value before deploying — this is production.

ENV=main

# ── Database (Neon production) ──────────────────────────────────────────────
# Dedicated Neon project for production. Enable point-in-time recovery
# in console.neon.tech → Project settings.
DATABASE_URL=postgres://kerf_user:XXX@ep-prod-XXX.eu-central-1.aws.neon.tech:5432/kerf?sslmode=require

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate ONCE for production with: openssl rand -hex 32
# If you rotate this, every active user session is invalidated — only do
# it if a leak is suspected.
JWT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
PASSWORD_PEPPER=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Object storage (Tigris — production bucket) ─────────────────────────────
# Run `flyctl storage create kerf-blobs --app kerf`
KERF_STORAGE_S3_BUCKET=kerf-blobs-XXXXXX
KERF_STORAGE_S3_ACCESS_KEY=tid_XXXXXXXXXXXXXXXXXXXXXXXXX
KERF_STORAGE_S3_SECRET_KEY=tsec_XXXXXXXXXXXXXXXXXXXXXXXXX
KERF_STORAGE_S3_ENDPOINT=https://fly.storage.tigris.dev
KERF_STORAGE_S3_REGION=auto
STORAGE_BACKEND=s3

# ── Payments (Paystack LIVE mode) ───────────────────────────────────────────
# Paystack Dashboard → Settings → API Keys → use the LIVE secret + public
# keys. Live mode requires KYC + activated account.
# Secret format:  sk_live_<32-char alphanumeric>
# Public format:  pk_live_<32-char alphanumeric>
CLOUD_PAYSTACK_SECRET_KEY=
CLOUD_PAYSTACK_PUBLIC_KEY=

# ── Email (Resend — production sender domain) ───────────────────────────────
# Verify `kerf.sh` in Resend with SPF + DKIM DNS records before sending.
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_DOMAIN=kerf.sh
RESEND_FROM_ADDRESS=Kerf <no-reply@kerf.sh>

# ── FX rate (USD ↔ ZAR) ─────────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── LLM providers ───────────────────────────────────────────────────────────
# At minimum: Anthropic + one cheap-tier provider (for the free tier to
# work). More providers = more user choice.
LLM_ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LLM_GOOGLE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LLM_DEEPSEEK_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LLM_MINIMAX_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional:
LLM_OPENAI_API_KEY=
LLM_MOONSHOT_API_KEY=

# ── OAuth (login providers — production callbacks) ──────────────────────────
# Google Cloud Console → Credentials → use the PRODUCTION OAuth app
# (separate from the dev one). Authorized redirect URI must be exact.
GOOGLE_CLIENT_ID=XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_REDIRECT_URL=https://kerf.sh/auth/google/callback

# github.com/settings/developers → New OAuth App (production)
GITHUB_CLIENT_ID=Iv1.XXXXXXXXXXXXXXXX
GITHUB_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GITHUB_REDIRECT_URL=https://kerf.sh/auth/github/callback

# ── Mode flags ──────────────────────────────────────────────────────────────
CLOUD_ENABLED=true
KERF_LOCAL_MODE=false
CORS_ORIGIN=https://kerf.sh
KERF_API_URL=https://kerf.sh
DEFAULT_MODEL=claude-opus-4-7

# ── Optional: distributor APIs (BOM auto-pricing) ───────────────────────────
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
MOUSER_API_KEY=

# ── Frontend Vite vars (compiled into bundle at build time) ─────────────────
VITE_API_URL=
VITE_GOOGLE_CLIENT_ID=
