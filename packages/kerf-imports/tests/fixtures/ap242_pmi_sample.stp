ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('AP242 PMI fixture for kerf test suite',''),'2;1');
FILE_NAME('ap242_pmi_sample.stp','2024-06-01T12:00:00',('Test Author'),('Kerf'),'','kerf','');
FILE_SCHEMA(('AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF { 1 0 10303 442 1 1 4 }'));
ENDSEC;
DATA;
/* Product */
#1=PRODUCT('BracketA','Steel mounting bracket',$,(#2));
#2=PRODUCT_CONTEXT('',#3,'mechanical');
#3=APPLICATION_CONTEXT('managed model based 3d engineering');

/* PMI annotation: straightness callout */
#10=DRAUGHTING_CALLOUT('Straightness 0.05',(#11));
#11=ANNOTATION_OCCURRENCE('straightness note',#12,(#13));
#12=ANNOTATION_PLANE('annotation plane A',#14,#15);
#13=PMI_REPRESENTATION_ITEM('straightness_pmi');
#14=AXIS2_PLACEMENT_3D('',#16,#17,#18);
#15=PLANAR_BOX($,(100.0,50.0),#14);
#16=CARTESIAN_POINT('',(0.0,0.0,0.0));
#17=DIRECTION('',(0.0,0.0,1.0));
#18=DIRECTION('',(1.0,0.0,0.0));

/* GD&T: flatness tolerance */
#20=FLATNESS_TOLERANCE('flatness_tol',#21,$,#22);
#21=MEASURE_WITH_UNIT(PLANE_ANGLE_MEASURE(0.02),#23);
#22=TOLERANCE_VALUE(0.02,0.0);
#23=LENGTH_UNIT(#24);
#24=SI_UNIT($,.MILLI.,.METRE.);

/* GD&T: perpendicularity with datum reference */
#30=GEOMETRIC_TOLERANCE_WITH_DATUM_REFERENCE('perp_tol',#31,$,#32,(#33));
#31=MEASURE_WITH_UNIT(PLANE_ANGLE_MEASURE(0.05),#23);
#32=TOLERANCE_VALUE(0.05,0.0);
#33=DATUM_REFERENCE(1,(#34));

/* Datum features */
#34=DATUM_FEATURE('datum_A',$,#1);
#35=DATUM('A',$,#34);
#36=DATUM_REFERENCE_COMPARTMENT((#35),$);
#37=DATUM_TARGET('datum_B_target','B',#38);
#38=CARTESIAN_POINT('',(10.0,0.0,0.0));

/* Dimensional size: a 25mm bore */
#40=DIMENSIONAL_SIZE('bore_diameter',#41,$);
#41=MEASURE_WITH_UNIT(LENGTH_MEASURE(25.0),#23);

/* Assembly linkage */
#50=NEXT_ASSEMBLY_USAGE_OCCURRENCE('1','','',#1,#1,$);
#51=NEXT_ASSEMBLY_USAGE_OCCURRENCE('2','','',#1,#1,$);

/* Geometric tolerance: straightness */
#60=STRAIGHTNESS_TOLERANCE('straight_tol',#61,$,#62);
#61=MEASURE_WITH_UNIT(PLANE_ANGLE_MEASURE(0.05),#23);
#62=TOLERANCE_VALUE(0.05,0.0);

ENDSEC;
END-ISO-10303-21;
