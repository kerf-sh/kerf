# -----------------------------------------------------------------------
# sky130_fd_sc_hd__dff_1 — D flip-flop (drive strength 1)
# -----------------------------------------------------------------------
MACRO sky130_fd_sc_hd__dff_1
  CLASS CORE ;
  ORIGIN 0.000 0.000 ;
  SIZE 3.680 BY 2.720 ;
  SYMMETRY X Y R90 ;
  SITE unithd ;

  PIN D
    DIRECTION INPUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 0.1296 ;
    PORT
      LAYER li1 ;
        RECT 0.000 1.245 0.510 1.415 ;
    END PORT
  END D

  PIN CLK
    DIRECTION INPUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 0.2592 ;
    PORT
      LAYER li1 ;
        RECT 0.000 0.885 0.510 1.055 ;
    END PORT
  END CLK

  PIN Q
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER li1 ;
        RECT 3.170 1.245 3.680 1.415 ;
    END PORT
  END Q

  PIN VPWR
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER met1 ;
        RECT 0.000 2.580 3.680 2.720 ;
    END PORT
  END VPWR

  PIN VGND
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER met1 ;
        RECT 0.000 0.000 3.680 0.140 ;
    END PORT
  END VGND

  OBS
    LAYER li1 ;
      RECT 0.000 0.320 3.680 2.400 ;
    LAYER met1 ;
      RECT 0.140 0.320 3.540 2.400 ;
  END OBS

END sky130_fd_sc_hd__dff_1

END LIBRARY
