# .env — Vite frontend configuration ONLY.
#
# Copy to `.env` (default), `.env.dev`, or `.env.main` per Vite's mode.
# The backend has moved to kerf.toml (see kerf.example.toml at the repo
# root). Anything other than VITE_* keys here is ignored.

# URL of the backend API. In dev, Vite proxies /api and /auth to this.
VITE_API_URL=http://localhost:8080

# Google OAuth client ID for the browser-side OAuth start. Must match
# auth.google.client_id in kerf.toml.
VITE_GOOGLE_CLIENT_ID=
