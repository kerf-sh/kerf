# Copy to .env (local), .env.dev (dev), .env.main (production).
# Variables prefixed with VITE_ are exposed to the browser.

# ---- Frontend (Vite) ----
VITE_API_URL=http://localhost:8080
VITE_GOOGLE_CLIENT_ID=

# ---- Backend (Go) ----
PORT=8080
ENV=local

# Postgres / Supabase
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kerf?sslmode=disable

# Auth
JWT_SECRET=dev-only-change-me-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
PASSWORD_PEPPER=dev-only-pepper

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# CORS
CORS_ORIGIN=http://localhost:5173

# LLM (chat)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# System user (seeded by `cmd/migrate`).
# If SYSTEM_USER_PASSWORD is empty, the seeder logs a warning and skips it.
SYSTEM_USER_EMAIL=exolutionza@gmail.com
SYSTEM_USER_NAME=Kerf System
SYSTEM_USER_PASSWORD=
