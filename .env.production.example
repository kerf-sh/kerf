# Kerf production secrets template.
#
# Copy to `.env.production` (gitignored) and fill in real values, then run:
#   ./scripts/deploy-fly.sh
#
# This file lives in the repo as a template — the real .env.production
# never gets committed. All values are uploaded to fly.io as secrets
# (encrypted at rest, exposed to machines as env vars).

# ── Database ────────────────────────────────────────────────────────────────
# Neon Postgres connection string. Get from console.neon.tech → Connection
# Details. Must include `?sslmode=require`.
DATABASE_URL=postgres://user:pass@host.neon.tech:5432/kerf?sslmode=require

# ── Auth ────────────────────────────────────────────────────────────────────
# JWT signing secret. Generate once with: openssl rand -hex 32
JWT_SECRET=

# ── Object storage (Tigris) ─────────────────────────────────────────────────
# Provisioned via `flyctl storage create kerf-blobs`. The command prints
# all four values. Copy here.
KERF_STORAGE_S3_BUCKET=kerf-blobs-xxxxxx
KERF_STORAGE_S3_ACCESS_KEY=tid_
KERF_STORAGE_S3_SECRET_KEY=tsec_
KERF_STORAGE_S3_ENDPOINT=https://fly.storage.tigris.dev
KERF_STORAGE_S3_REGION=auto
STORAGE_BACKEND=s3

# ── Payments (Paystack) ─────────────────────────────────────────────────────
# From paystack.com dashboard → Settings → API Keys. Use sk_live_* for
# production; sk_test_* for a staging fly app.
CLOUD_PAYSTACK_SECRET_KEY=sk_live_
CLOUD_PAYSTACK_PUBLIC_KEY=pk_live_

# ── Email (Resend) ──────────────────────────────────────────────────────────
# From resend.com → API Keys. Domain must be verified (SPF + DKIM DNS
# records added).
RESEND_API_KEY=re_
RESEND_FROM_DOMAIN=kerf.sh

# ── FX rate (USD ↔ ZAR) ─────────────────────────────────────────────────────
# Pick one: openexchangerates.org, exchangerate.host, fixer.io, ECB.
# openexchangerates.org has a free tier (1k calls/mo, enough).
EXCHANGE_RATE_API_KEY=

# ── LLM providers ───────────────────────────────────────────────────────────
# At minimum: Anthropic + one cheap-tier provider (for the free tier).
# More providers = more user choice.
LLM_ANTHROPIC_API_KEY=sk-ant-
LLM_GOOGLE_API_KEY=
LLM_DEEPSEEK_API_KEY=
LLM_MINIMAX_API_KEY=
# Optional:
LLM_OPENAI_API_KEY=
LLM_MOONSHOT_API_KEY=

# ── OAuth (login providers) ─────────────────────────────────────────────────
# From console.cloud.google.com → APIs & Services → Credentials.
# Redirect URI: https://kerf.sh/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# From github.com/settings/developers → New OAuth App.
# Redirect URI: https://kerf.sh/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Mode flags ──────────────────────────────────────────────────────────────
# Both required for hosted deployments.
CLOUD_ENABLED=true
KERF_LOCAL_MODE=false

# ── Optional: distributor APIs (BOM auto-pricing) ───────────────────────────
# Wire these in once Library/BOM users want live pricing.
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
MOUSER_API_KEY=
