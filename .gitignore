# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

.claude/

node_modules
dist
dist-ssr
*.local

# Embedded frontend bundle: built by `npm run build:web`, ignored except
# for the placeholder that keeps the directory present for //go:embed.
backend/internal/web/dist/*
!backend/internal/web/dist/.gitkeep

# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Env (commit only .env.example) — frontend Vite vars only.
.env
.env.dev
.env.main
.env.*.local

# Backend config (commit only kerf.example.toml).
kerf.toml

# Go
backend/bin/
backend/tmp/
*.test
*.out

# Compiled Go binaries (built into repo root and backend/). These rooted
# patterns (leading slash) only match the top-level binary; they do NOT
# shadow packages/kerf-cloud/ or packages/kerf-oss/, which live under
# packages/.
/kerf
/kerf-cloud
/kerf-oss
/backend/server
/backend/test
/backend/migrate

# Local storage backend (STEP files, uploads)
.kerf-storage/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Misc
.cache/
