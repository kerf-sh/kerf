# Kerf dev/staging environment template.
#
# Copy to `.env.dev` (gitignored) and replace XXX placeholders with real
# values, then run:
#   ./scripts/deploy-fly.sh --dev
#
# This deploys to the `kerf-dev` fly app + `kerf-dev-workers`.
# Use Paystack TEST keys here, not live keys. Run a separate Neon
# branch/project for dev so test data doesn't contaminate production.

ENV=dev

# ── Database (Neon dev branch) ──────────────────────────────────────────────
# Recommended: a separate Neon project, OR a branch off your main project.
# Console: console.neon.tech → Branches → "Create branch" off main.
DATABASE_URL=postgres://kerf_dev_user:XXX@ep-dev-XXX.eu-central-1.aws.neon.tech:5432/kerf_dev?sslmode=require

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
PASSWORD_PEPPER=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Object storage (Tigris — dev bucket) ────────────────────────────────────
# Run `flyctl storage create kerf-blobs-dev --app kerf-dev`
KERF_STORAGE_S3_BUCKET=kerf-blobs-dev-XXXXXX
KERF_STORAGE_S3_ACCESS_KEY=tid_XXXXXXXXXXXXXXXXXXXXXXXXX
KERF_STORAGE_S3_SECRET_KEY=tsec_XXXXXXXXXXXXXXXXXXXXXXXXX
KERF_STORAGE_S3_ENDPOINT=https://fly.storage.tigris.dev
KERF_STORAGE_S3_REGION=auto
STORAGE_BACKEND=s3

# ── Payments (Paystack TEST mode) ───────────────────────────────────────────
# Paystack Dashboard → Settings → API Keys → use the TEST secret + public keys.
# Secret format:  sk_test_<32-char alphanumeric>
# Public format:  pk_test_<32-char alphanumeric>
CLOUD_PAYSTACK_SECRET_KEY=
CLOUD_PAYSTACK_PUBLIC_KEY=

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Same key as main, but use a subdomain so dev emails don't hit production
# reputation. Verify the subdomain in Resend (SPF + DKIM).
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_DOMAIN=dev-mail.kerf.sh
RESEND_FROM_ADDRESS=Kerf Dev <no-reply@dev-mail.kerf.sh>

# ── FX rate (USD ↔ ZAR) ─────────────────────────────────────────────────────
# openexchangerates.org free tier (1k calls/mo) is enough for dev + main.
EXCHANGE_RATE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── LLM providers ───────────────────────────────────────────────────────────
# Same keys as production are fine; cap with provider dashboard spend limits.
LLM_ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LLM_GOOGLE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LLM_DEEPSEEK_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LLM_MINIMAX_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional:
LLM_OPENAI_API_KEY=
LLM_MOONSHOT_API_KEY=

# ── OAuth (login providers — dev callbacks) ─────────────────────────────────
# Create a SEPARATE OAuth app for dev so the callback URL can point at
# dev.kerf.sh (or kerf-dev.fly.dev for staging-no-domain).
# Google Cloud Console → Credentials → New OAuth client.
GOOGLE_CLIENT_ID=XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_REDIRECT_URL=https://dev.kerf.sh/auth/google/callback

# github.com/settings/developers → New OAuth App
GITHUB_CLIENT_ID=Iv1.XXXXXXXXXXXXXXXX
GITHUB_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GITHUB_REDIRECT_URL=https://dev.kerf.sh/auth/github/callback

# ── Mode flags ──────────────────────────────────────────────────────────────
CLOUD_ENABLED=true
KERF_LOCAL_MODE=false
CORS_ORIGIN=https://dev.kerf.sh
KERF_API_URL=https://dev.kerf.sh
DEFAULT_MODEL=claude-opus-4-7

# ── Optional: distributor APIs (BOM auto-pricing) ───────────────────────────
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
MOUSER_API_KEY=

# ── Frontend Vite vars (compiled into bundle at build time) ─────────────────
# Same-origin in production so usually blank. Set if frontend lives on a
# different domain from the API.
VITE_API_URL=
VITE_GOOGLE_CLIENT_ID=
